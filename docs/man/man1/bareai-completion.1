.SH NAME
bareai-completion - Generate shell completion scripts


.SH SYNOPSIS
\fBbareai completion [bash|zsh|fish|powershell]\fP


.SH DESCRIPTION
Generate shell completion scripts for bareai.

.PP
To load completions:

.PP
Bash:
  $ source <(bareai completion bash)

.PP
# or persist:
  $ bareai completion bash > /etc/bash_completion.d/bareai

.PP
Zsh:
  $ source <(bareai completion zsh)

.PP
# or persist:
  $ bareai completion zsh > "${fpath[1]}/_bareai"

.PP
Fish:
  $ bareai completion fish | source

.PP
# or persist:
  $ bareai completion fish > ~/.config/fish/completions/bareai.fish

.PP
PowerShell:
  PS> bareai completion powershell | Out-String | Invoke-Expression

.PP
# or persist:
  PS> bareai completion powershell > bareai.ps1


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for completion


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-j\fP, \fB--json\fP[=false]
	output in JSON format

.PP
\fB--no-color\fP[=false]
	disable colored output

.PP
\fB--timeout\fP=10s
	timeout for probes and API calls


.SH SEE ALSO
\fBbareai(1)\fP


