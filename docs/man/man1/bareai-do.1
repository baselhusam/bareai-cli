.SH NAME
bareai-do - Confirm-gated actions tied to doctor findings


.SH SYNOPSIS
\fBbareai do [flags]\fP


.SH DESCRIPTION
Run a small set of finding-scoped actions after diagnosis.

.PP
Mutating verbs require --finding and confirmation (--yes or interactive prompt).
Use "bareai do plan " or --dry-run to preview changes without side effects.

.PP
MCP remains read-only; actions are CLI-only in Phase 12.


.SH OPTIONS
\fB--container\fP=""
	container name or ID from snapshot

.PP
\fB--dry-run\fP[=false]
	preview only; no side effects

.PP
\fB--endpoint\fP=""
	LLM endpoint for reprobe

.PP
\fB--finding\fP=""
	doctor finding ID (required for mutate verbs)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for do

.PP
\fB--no-reprobe\fP[=false]
	skip automatic reprobe after restart/free-gpu

.PP
\fB--tail\fP=100
	log lines for logs verb

.PP
\fB--yes\fP[=false]
	skip interactive confirmation for mutating verbs


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-j\fP, \fB--json\fP[=false]
	output in JSON format

.PP
\fB--no-color\fP[=false]
	disable colored output

.PP
\fB--timeout\fP=10s
	timeout for probes and API calls


.SH EXAMPLE
.EX
  bareai do list
  bareai do plan restart --finding llm.unreachable --container ollama
  bareai do restart --finding llm.unreachable --container ollama --yes
  bareai do logs --finding llm.unreachable --tail 200
  bareai do reprobe --finding llm.no_models --endpoint http://127.0.0.1:11434
  bareai do free-gpu --finding gpu.vram_high --container vllm --yes
.EE


