.SH NAME
bareai-watch - Launch live TUI monitoring dashboard


.SH SYNOPSIS
\fBbareai watch [flags]\fP


.SH DESCRIPTION
Open an interactive Bubble Tea dashboard for browsing and monitoring infrastructure.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for watch

.PP
\fB--refresh\fP=3s
	interval between snapshot refreshes


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-j\fP, \fB--json\fP[=false]
	output in JSON format

.PP
\fB--no-color\fP[=false]
	disable colored output

.PP
\fB--timeout\fP=10s
	timeout for probes and API calls


.SH EXAMPLE
.EX
  bareai watch
  bareai watch --refresh 5s
.EE


